<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/culturalheritage-museum#"
     xml:base="http://www.semanticweb.org/culturalheritage-museum"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dcterms="http://purl.org/dc/terms/">
  <owl:Ontology rdf:about="http://www.semanticweb.org/culturalheritage-museum">
    <rdfs:label>Cultural Heritage and Museum Ontology</rdfs:label>
    <rdfs:comment>A compact OWL 2 ontology for museum collections, heritage objects, exhibitions, conservation, and digital documentation.</rdfs:comment>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
  </owl:Ontology>

  <owl:Class rdf:about="#CulturalHeritageObject">
    <rdfs:label>CulturalHeritageObject</rdfs:label>
    <rdfs:comment>A physical or digital resource with cultural heritage value.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="#Artifact">
    <rdfs:label>Artifact</rdfs:label>
    <rdfs:comment>A movable cultural object preserved by a museum or institution.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#CulturalHeritageObject"/>
  </owl:Class>

  <owl:Class rdf:about="#Artwork">
    <rdfs:label>Artwork</rdfs:label>
    <rdfs:comment>A creative cultural object such as a painting or sculpture.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#CulturalHeritageObject"/>
  </owl:Class>

  <owl:Class rdf:about="#Painting">
    <rdfs:label>Painting</rdfs:label>
    <rdfs:comment>An artwork created using paint on a surface.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Artwork"/>
  </owl:Class>

  <owl:Class rdf:about="#Sculpture">
    <rdfs:label>Sculpture</rdfs:label>
    <rdfs:comment>A three-dimensional artwork.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Artwork"/>
  </owl:Class>

  <owl:Class rdf:about="#Manuscript">
    <rdfs:label>Manuscript</rdfs:label>
    <rdfs:comment>A handwritten or historically significant written document.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Artifact"/>
  </owl:Class>

  <owl:Class rdf:about="#Coin">
    <rdfs:label>Coin</rdfs:label>
    <rdfs:comment>A small metallic object used as currency or heritage evidence.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Artifact"/>
  </owl:Class>

  <owl:Class rdf:about="#Textile">
    <rdfs:label>Textile</rdfs:label>
    <rdfs:comment>A heritage object made from woven or embroidered material.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Artifact"/>
  </owl:Class>

  <owl:Class rdf:about="#HeritageSite">
    <rdfs:label>HeritageSite</rdfs:label>
    <rdfs:comment>A location with historical, archaeological, or cultural importance.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#CulturalHeritageObject"/>
  </owl:Class>

  <owl:Class rdf:about="#Agent">
    <rdfs:label>Agent</rdfs:label>
    <rdfs:comment>A person or organization involved in heritage activities.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="#Artist">
    <rdfs:label>Artist</rdfs:label>
    <rdfs:comment>An agent who creates artworks or cultural objects.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Agent"/>
  </owl:Class>

  <owl:Class rdf:about="#Curator">
    <rdfs:label>Curator</rdfs:label>
    <rdfs:comment>An agent responsible for managing collections and exhibitions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Agent"/>
  </owl:Class>

  <owl:Class rdf:about="#Conservator">
    <rdfs:label>Conservator</rdfs:label>
    <rdfs:comment>An agent responsible for preservation and restoration work.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Agent"/>
  </owl:Class>

  <owl:Class rdf:about="#Researcher">
    <rdfs:label>Researcher</rdfs:label>
    <rdfs:comment>An agent who studies and documents heritage resources.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Agent"/>
  </owl:Class>

  <owl:Class rdf:about="#Museum">
    <rdfs:label>Museum</rdfs:label>
    <rdfs:comment>An institution that collects, preserves, and displays heritage objects.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#CulturalInstitution"/>
  </owl:Class>

  <owl:Class rdf:about="#CulturalInstitution">
    <rdfs:label>CulturalInstitution</rdfs:label>
    <rdfs:comment>An organization involved in heritage preservation or education.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Agent"/>
  </owl:Class>

  <owl:Class rdf:about="#Collection">
    <rdfs:label>Collection</rdfs:label>
    <rdfs:comment>A group of heritage objects managed together.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="#Exhibition">
    <rdfs:label>Exhibition</rdfs:label>
    <rdfs:comment>A public presentation of heritage objects.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="#Archive">
    <rdfs:label>Archive</rdfs:label>
    <rdfs:comment>A managed repository of records or heritage documentation.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="#HistoricalPeriod">
    <rdfs:label>HistoricalPeriod</rdfs:label>
    <rdfs:comment>A named time period relevant to cultural history.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="#Event">
    <rdfs:label>Event</rdfs:label>
    <rdfs:comment>An occurrence related to heritage objects or institutions.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="#AcquisitionEvent">
    <rdfs:label>AcquisitionEvent</rdfs:label>
    <rdfs:comment>An event in which an object is obtained by an institution.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Event"/>
  </owl:Class>

  <owl:Class rdf:about="#RestorationEvent">
    <rdfs:label>RestorationEvent</rdfs:label>
    <rdfs:comment>An event involving repair or conservation of an object.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Event"/>
  </owl:Class>

  <owl:Class rdf:about="#ExhibitionEvent">
    <rdfs:label>ExhibitionEvent</rdfs:label>
    <rdfs:comment>An event in which objects are displayed publicly.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Event"/>
  </owl:Class>

  <owl:Class rdf:about="#Location">
    <rdfs:label>Location</rdfs:label>
    <rdfs:comment>A geographical place.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="#Country">
    <rdfs:label>Country</rdfs:label>
    <rdfs:comment>A country location.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Location"/>
  </owl:Class>

  <owl:Class rdf:about="#City">
    <rdfs:label>City</rdfs:label>
    <rdfs:comment>A city location.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#Location"/>
  </owl:Class>

  <owl:Class rdf:about="#MediaObject">
    <rdfs:label>MediaObject</rdfs:label>
    <rdfs:comment>A digital or physical documentation resource.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="#Image">
    <rdfs:label>Image</rdfs:label>
    <rdfs:comment>A visual documentation object.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#MediaObject"/>
  </owl:Class>

  <owl:Class rdf:about="#Material">
    <rdfs:label>Material</rdfs:label>
    <rdfs:comment>A substance used to create a heritage object.</rdfs:comment>
  </owl:Class>

  <owl:ObjectProperty rdf:about="#hasCreator">
    <rdfs:label>hasCreator</rdfs:label>
    <rdfs:comment>Links a heritage object to the artist who created it.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="#Artist"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#displayedIn">
    <rdfs:label>displayedIn</rdfs:label>
    <rdfs:comment>Links an object to the museum where it is displayed.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="#Museum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#belongsToCollection">
    <rdfs:label>belongsToCollection</rdfs:label>
    <rdfs:comment>Links an object to its collection.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="#Collection"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#associatedWithPeriod">
    <rdfs:label>associatedWithPeriod</rdfs:label>
    <rdfs:comment>Links an object to a historical period.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="#HistoricalPeriod"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#madeOf">
    <rdfs:label>madeOf</rdfs:label>
    <rdfs:comment>States the material of an object.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="#Material"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#curatedBy">
    <rdfs:label>curatedBy</rdfs:label>
    <rdfs:comment>Links an exhibition to its curator.</rdfs:comment>
    <rdfs:domain rdf:resource="#Exhibition"/>
    <rdfs:range rdf:resource="#Curator"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#organizedBy">
    <rdfs:label>organizedBy</rdfs:label>
    <rdfs:comment>Links an exhibition event to its organizer.</rdfs:comment>
    <rdfs:domain rdf:resource="#ExhibitionEvent"/>
    <rdfs:range rdf:resource="#CulturalInstitution"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#locatedIn">
    <rdfs:label>locatedIn</rdfs:label>
    <rdfs:comment>Links a heritage object or site to a location.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="#Location"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#documentedIn">
    <rdfs:label>documentedIn</rdfs:label>
    <rdfs:comment>Links an object to its documentation.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="#MediaObject"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#restoredBy">
    <rdfs:label>restoredBy</rdfs:label>
    <rdfs:comment>Links restoration activity to a conservator.</rdfs:comment>
    <rdfs:domain rdf:resource="#RestorationEvent"/>
    <rdfs:range rdf:resource="#Conservator"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#restoresObject">
    <rdfs:label>restoresObject</rdfs:label>
    <rdfs:comment>Links a restoration event to the object restored.</rdfs:comment>
    <rdfs:domain rdf:resource="#RestorationEvent"/>
    <rdfs:range rdf:resource="#CulturalHeritageObject"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#preservedBy">
    <rdfs:label>preservedBy</rdfs:label>
    <rdfs:comment>Links an object to the institution preserving it.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="#CulturalInstitution"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#references">
    <rdfs:label>references</rdfs:label>
    <rdfs:comment>Links documentation to the heritage object it references.</rdfs:comment>
    <rdfs:domain rdf:resource="#MediaObject"/>
    <rdfs:range rdf:resource="#CulturalHeritageObject"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#owns">
    <rdfs:label>owns</rdfs:label>
    <rdfs:comment>Links a museum to an object it owns.</rdfs:comment>
    <rdfs:domain rdf:resource="#Museum"/>
    <rdfs:range rdf:resource="#CulturalHeritageObject"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#manages">
    <rdfs:label>manages</rdfs:label>
    <rdfs:comment>Links an institution to a managed collection.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalInstitution"/>
    <rdfs:range rdf:resource="#Collection"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasLocation">
    <rdfs:label>hasLocation</rdfs:label>
    <rdfs:comment>Links an institution to its location.</rdfs:comment>
    <rdfs:domain rdf:resource="#Museum"/>
    <rdfs:range rdf:resource="#Location"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#participatesInEvent">
    <rdfs:label>participatesInEvent</rdfs:label>
    <rdfs:comment>Links an agent to a heritage-related event.</rdfs:comment>
    <rdfs:domain rdf:resource="#Agent"/>
    <rdfs:range rdf:resource="#Event"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#acquiresObject">
    <rdfs:label>acquiresObject</rdfs:label>
    <rdfs:comment>Links an acquisition event to the acquired object.</rdfs:comment>
    <rdfs:domain rdf:resource="#AcquisitionEvent"/>
    <rdfs:range rdf:resource="#CulturalHeritageObject"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#exhibitsObject">
    <rdfs:label>exhibitsObject</rdfs:label>
    <rdfs:comment>Links an exhibition to an object displayed in it.</rdfs:comment>
    <rdfs:domain rdf:resource="#Exhibition"/>
    <rdfs:range rdf:resource="#CulturalHeritageObject"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasPart">
    <rdfs:label>hasPart</rdfs:label>
    <rdfs:comment>Links a collection to one of its objects.</rdfs:comment>
    <rdfs:domain rdf:resource="#Collection"/>
    <rdfs:range rdf:resource="#CulturalHeritageObject"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="#hasTitle">
    <rdfs:label>hasTitle</rdfs:label>
    <rdfs:comment>Title or name of a heritage resource.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#hasDescription">
    <rdfs:label>hasDescription</rdfs:label>
    <rdfs:comment>Textual description of a resource.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#inventoryNumber">
    <rdfs:label>inventoryNumber</rdfs:label>
    <rdfs:comment>Museum inventory identifier.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#creationDate">
    <rdfs:label>creationDate</rdfs:label>
    <rdfs:comment>Date or approximate date of creation.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#acquisitionDate">
    <rdfs:label>acquisitionDate</rdfs:label>
    <rdfs:comment>Date when an object was acquired.</rdfs:comment>
    <rdfs:domain rdf:resource="#AcquisitionEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#conditionStatus">
    <rdfs:label>conditionStatus</rdfs:label>
    <rdfs:comment>Current preservation condition.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#height">
    <rdfs:label>height</rdfs:label>
    <rdfs:comment>Height measurement.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#width">
    <rdfs:label>width</rdfs:label>
    <rdfs:comment>Width measurement.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#estimatedValue">
    <rdfs:label>estimatedValue</rdfs:label>
    <rdfs:comment>Estimated financial value.</rdfs:comment>
    <rdfs:domain rdf:resource="#CulturalHeritageObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#fileFormat">
    <rdfs:label>fileFormat</rdfs:label>
    <rdfs:comment>Digital file format.</rdfs:comment>
    <rdfs:domain rdf:resource="#MediaObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#publicationYear">
    <rdfs:label>publicationYear</rdfs:label>
    <rdfs:comment>Year of publication or documentation.</rdfs:comment>
    <rdfs:domain rdf:resource="#MediaObject"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#materialType">
    <rdfs:label>materialType</rdfs:label>
    <rdfs:comment>Material category name.</rdfs:comment>
    <rdfs:domain rdf:resource="#Material"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="#TheStarryNight">
    <rdf:type rdf:resource="#Painting"/>
    <rdfs:label>TheStarryNight</rdfs:label>
    <hasTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Starry Night</hasTitle>
    <inventoryNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MOMA-001</inventoryNumber>
    <conditionStatus rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stable</conditionStatus>
    <hasCreator rdf:resource="#VincentVanGogh"/>
    <displayedIn rdf:resource="#MuseumOfModernArt"/>
    <associatedWithPeriod rdf:resource="#PostImpressionism"/>
    <madeOf rdf:resource="#OilPaint"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#MonaLisa">
    <rdf:type rdf:resource="#Painting"/>
    <rdfs:label>MonaLisa</rdfs:label>
    <hasTitle rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mona Lisa</hasTitle>
    <inventoryNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LOUVRE-001</inventoryNumber>
    <conditionStatus rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Protected</conditionStatus>
    <hasCreator rdf:resource="#LeonardoDaVinci"/>
    <displayedIn rdf:resource="#LouvreMuseum"/>
    <associatedWithPeriod rdf:resource="#Renaissance"/>
    <madeOf rdf:resource="#OilPaint"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#VincentVanGogh">
    <rdf:type rdf:resource="#Artist"/>
    <rdfs:label>VincentVanGogh</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#LeonardoDaVinci">
    <rdf:type rdf:resource="#Artist"/>
    <rdfs:label>LeonardoDaVinci</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#MuseumOfModernArt">
    <rdf:type rdf:resource="#Museum"/>
    <rdfs:label>MuseumOfModernArt</rdfs:label>
    <hasLocation rdf:resource="#NewYorkCity"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#LouvreMuseum">
    <rdf:type rdf:resource="#Museum"/>
    <rdfs:label>LouvreMuseum</rdfs:label>
    <hasLocation rdf:resource="#ParisCity"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#PostImpressionism">
    <rdf:type rdf:resource="#HistoricalPeriod"/>
    <rdfs:label>PostImpressionism</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Renaissance">
    <rdf:type rdf:resource="#HistoricalPeriod"/>
    <rdfs:label>Renaissance</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#OilPaint">
    <rdf:type rdf:resource="#Material"/>
    <rdfs:label>OilPaint</rdfs:label>
    <materialType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Paint</materialType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#NewYorkCity">
    <rdf:type rdf:resource="#City"/>
    <rdfs:label>NewYorkCity</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#ParisCity">
    <rdf:type rdf:resource="#City"/>
    <rdfs:label>ParisCity</rdfs:label>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#MoMACollection">
    <rdf:type rdf:resource="#Collection"/>
    <rdfs:label>MoMACollection</rdfs:label>
    <hasPart rdf:resource="#TheStarryNight"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#LouvreCollection">
    <rdf:type rdf:resource="#Collection"/>
    <rdfs:label>LouvreCollection</rdfs:label>
    <hasPart rdf:resource="#MonaLisa"/>
  </owl:NamedIndividual>

</rdf:RDF>